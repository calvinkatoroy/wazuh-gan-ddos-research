<!-- GANDD-Bridge custom Wazuh rules
     Deploy to: /var/ossec/etc/rules/local_rules.xml  (on VM3 Wazuh Manager)
     Blue Team component — Calvin Wirathama Katoroy (2306242395)
-->
<group name="gandd,ddos,attack,">

  <!-- ── Primary GANDD alert rule ───────────────────────────────────────────
       Fires whenever GANDD-Bridge writes a GANDD_ALERT line.
       Level 12 ensures Active Response (firewall-drop) is triggered.
  -->
  <rule id="100200" level="12">
    <match>GANDD_ALERT</match>
    <description>GANDD-Bridge: ML discriminator detected synthetic/adversarial DDoS pattern</description>
    <mitre>
      <id>T1498</id>
      <id>T1499</id>
    </mitre>
    <group>attack,ddos,ml_detection,</group>
  </rule>

  <!-- ── High-confidence alert (confidence >= 0.90) ────────────────────────
       Level 15 for immediate escalation.
  -->
  <rule id="100201" level="15">
    <if_sid>100200</if_sid>
    <match>confidence=0\.9[0-9]</match>
    <description>GANDD-Bridge: High-confidence adversarial DDoS (confidence >= 0.90)</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,ddos,ml_detection,high_confidence,</group>
  </rule>

  <!-- ── GANDD alert with source IP extraction ─────────────────────────────
       Extracts the attacking source IP for Active Response.
  -->
  <rule id="100202" level="12">
    <if_sid>100200</if_sid>
    <regex>src_ip=(\S+)</regex>
    <description>GANDD-Bridge: Attack source IP identified for automated blocking</description>
    <group>attack,ddos,ml_detection,firewall_block,</group>
  </rule>

</group>

<group name="suricata,ddos,attack,">

  <!-- ── Suricata baseline DDoS detection ──────────────────────────────────
       Matches ET DROP and high-priority Suricata alerts forwarded via eve.json.
       Level 12 triggers active response (firewall-drop).
  -->
  <rule id="100210" level="12">
    <if_sid>86601</if_sid>
    <match>ET DROP</match>
    <description>Suricata: DDoS flood traffic detected (ET DROP)</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,ddos,ids_alert,firewall_block,</group>
  </rule>

  <rule id="100211" level="12">
    <if_sid>86601</if_sid>
    <field name="alert.category">Attempted Denial of Service</field>
    <description>Suricata: Attempted DoS attack detected</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,ddos,ids_alert,firewall_block,</group>
  </rule>

  <rule id="100212" level="12">
    <if_sid>86601</if_sid>
    <field name="alert.category">Misc Attack</field>
    <field name="alert.severity">1|2</field>
    <description>Suricata: High-priority misc attack (priority 1 or 2)</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,ddos,ids_alert,firewall_block,</group>
  </rule>

</group>
